# Copy to deploy/service.env (gitignored) and fill in. Consumed by deploy/install.sh
# to render the LaunchAgent. Keeps real IP/keys out of the repo.
MLX_LAZYSERVE_HOST=0.0.0.0
MLX_LAZYSERVE_PORT=41434
MLX_LAZYSERVE_IDLE_TIMEOUT=600
MLX_LAZYSERVE_MAX_TOKENS=8192
# Default thinking/reasoning: false = clean answers; per-request "enable_thinking" overrides.
MLX_LAZYSERVE_ENABLE_THINKING=false
# >0 quantizes the KV cache to N bits (e.g. 8) — less memory / longer context, slight quality cost.
MLX_LAZYSERVE_KV_BITS=0
# >0 raises the Metal wired-memory limit on start (needs the NOPASSWD sudoers rule).
MLX_LAZYSERVE_WIRED_LIMIT_MB=22000
# Bearer token required on /v1/* and /admin/*; empty = open (rely on Tailscale).
MLX_LAZYSERVE_API_KEYS=

# --- Embedded Telegram bot (optional) ---
# BotFather token; empty = bot OFF. When set, the service also runs a Telegram bot that
# replies to @mentions / replies-to-it in groups (needs the 'telegram' extra, installed
# automatically by install.sh).
MLX_LAZYSERVE_TG_BOT_TOKEN=
# Default model the bot chats with (each user overrides via /model); empty = server default.
MLX_LAZYSERVE_TG_MODEL=
# System persona; empty = built-in uncensored persona (candid, no moralizing/refusals).
MLX_LAZYSERVE_TG_SYSTEM_PROMPT=
# Max output tokens per reply; empty = MLX_LAZYSERVE_MAX_TOKENS.
MLX_LAZYSERVE_TG_MAX_TOKENS=
# KV-cache quant bits for the bot (4 = fast/light default; 8 = higher quality; 0 = off).
MLX_LAZYSERVE_TG_KV_BITS=4
# Per-(group,user) conversation turns kept as context.
MLX_LAZYSERVE_TG_HISTORY_TURNS=8
# Default reasoning state (each user overrides via /think); on = show an expandable blockquote.
MLX_LAZYSERVE_TG_ENABLE_THINKING=false
# Owner user ids (comma-separated): only they may add the bot to a group (others -> it leaves),
# and they approve/deny strangers' first private message before the bot will reply. Approved DM
# users are saved to SQLite. Empty = no restriction. Find your id via @userinfobot.
# NOTE: an owner must have started a DM with the bot once, or approval requests can't reach them.
MLX_LAZYSERVE_TG_OWNER_IDS=
# SQLite file for per-(group,user) history (survives restarts). install.sh defaults it to
# the runtime dir and preserves it across redeploys; empty here uses that default.
MLX_LAZYSERVE_TG_DB_PATH=

HF_HUB_DISABLE_XET=1
