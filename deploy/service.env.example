# Copy to deploy/service.env (gitignored) and fill in. Consumed by deploy/install.sh
# to render the LaunchAgent. Keeps real IP/keys out of the repo.
MLX_LAZYSERVE_HOST=0.0.0.0
MLX_LAZYSERVE_PORT=41434
MLX_LAZYSERVE_IDLE_TIMEOUT=600
MLX_LAZYSERVE_MAX_TOKENS=8192
# Default thinking/reasoning: false = clean answers; per-request "enable_thinking" overrides.
MLX_LAZYSERVE_ENABLE_THINKING=false
# >0 quantizes the KV cache to N bits (e.g. 8) — less memory / longer context, slight quality cost.
MLX_LAZYSERVE_KV_BITS=0
# >0 raises the Metal wired-memory limit on start (needs the NOPASSWD sudoers rule).
MLX_LAZYSERVE_WIRED_LIMIT_MB=22000
# Bearer token required on /v1/* and /admin/*; empty = open (rely on Tailscale).
MLX_LAZYSERVE_API_KEYS=
HF_HUB_DISABLE_XET=1
